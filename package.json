{
  "name": "@joshbochu/skim",
  "version": "0.2.0",
  "description": "🎯 agent skill for signal > noise",
  "keywords": [
    "pi-package",
    "pi-extension",
    "skim",
    "readability"
  ],
  "license": "MIT",
  "author": "joshbochu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshbochu/skim.git"
  },
  "homepage": "https://github.com/joshbochu/skim",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test evals/*.test.mjs",
    "eval:lint": "node evals/lint.mjs --gold",
    "eval:dry": "node evals/run.mjs --dry-run",
    "eval": "node evals/run.mjs",
    "eval:skim-v2:dry": "node evals/run.mjs --dry-run --profile skim-v2 --cases-file evals/skim-v2-cases.json",
    "eval:skim-v2": "node evals/run.mjs --profile skim-v2 --cases-file evals/skim-v2-cases.json",
    "prepublishOnly": "npm test && npm run eval:lint && npm run eval:dry && npm run eval:skim-v2:dry"
  },
  "files": [
    "extensions",
    "rules",
    "skills",
    "evals/capture.test.mjs",
    "evals/cases.json",
    "evals/skim-v2-cases.json",
    "evals/fixtures",
    "evals/gold",
    "evals/lint.mjs",
    "evals/lint.test.mjs",
    "evals/README.md",
    "evals/run.mjs",
    "IMPROVING.md",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/skim.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  }
}
